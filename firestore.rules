// ── FILE: firestore.rules ──────────────────────────────────────────
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ───────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function isValidThread() {
      let d = request.resource.data;
      return d.keys().hasAll(['title', 'body', 'tag', 'uid', 'displayName', 'createdAt'])
        && d.title is string && d.title.size() > 0 && d.title.size() < 300
        && d.body is string && d.body.size() > 0 && d.body.size() < 5000
        && d.uid == request.auth.uid;
    }

    function isValidMessage() {
      let d = request.resource.data;
      return d.keys().hasAll(['uid', 'displayName', 'timestamp'])
        && d.uid == request.auth.uid;
    }

    // ─── /users/{uid} ───────────────────────────────────────────────
    match /users/{uid} {
      allow read: if true;
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if false;

      // ─── /users/{uid}/notifications/{notifId} ─────────────────────
      match /notifications/{notifId} {
        allow read, write: if isOwner(uid);
      }
    }

    // ─── /threads/{threadId} ────────────────────────────────────────
    match /threads/{threadId} {
      allow read: if true;
      allow create: if isAuth() && isValidThread();
      allow update: if isAuth() && (
        // Owner can update anything
        resource.data.uid == request.auth.uid
        ||
        // Any authenticated user can update only upvotes + upvotedBy
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['upvotes', 'upvotedBy'])
      );
      allow delete: if isAuth() && resource.data.uid == request.auth.uid;
    }

    // ─── /rooms/{roomId}/messages ────────────────────────────────────
    match /rooms/{roomId} {
      allow read: if isAuth();

      match /messages/{messageId} {
        allow read: if isAuth();
        allow create: if isAuth() && isValidMessage();
        allow update, delete: if isAuth() && resource.data.uid == request.auth.uid;
      }

      match /presence/{uid} {
        allow read: if isAuth();
        allow write: if isOwner(uid);
      }
    }

    // ─── /live-riders/{uid} ──────────────────────────────────────────
    match /live-riders/{uid} {
      allow read: if isAuth();
      allow write: if isOwner(uid);
    }

    // ─── /meetup-points/{pointId} ────────────────────────────────────
    match /meetup-points/{pointId} {
      allow read: if isAuth();
      allow create: if isAuth()
        && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if isAuth()
        && resource.data.createdBy == request.auth.uid;
    }

    // ─── /rideActivity/{activityId} ──────────────────────────────────
    match /rideActivity/{activityId} {
      allow read: if true;
      allow create: if isAuth()
        && request.resource.data.uid == request.auth.uid;
      allow update: if isAuth() && (
        resource.data.uid == request.auth.uid
        || request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['likes', 'likedBy'])
      );
      allow delete: if isAuth() && resource.data.uid == request.auth.uid;
    }

    // ─── /leaderboard/{docId} ────────────────────────────────────────
    match /leaderboard/{docId} {
      allow read: if true;
      // Only allow client-side writes via transactions from authenticated users
      allow write: if isAuth();
    }
  }
}
